---
import "../styles/global.css";
import { getPageContent } from "../lib/api.js";
import { resolveMediaUrl } from "../lib/media.js";

const {
  title = "Soluciones TIC",
  description = "Videovigilancia IP, redes y conectividad profesional.",
  canonical = "",
  site,
  noindex = false
} = Astro.props;

const requestOrigin = Astro.url.origin;

const [redesPage, servidoresPage, blogPage, soportePage] = await Promise.all([
  getPageContent("redes-y-vpn", { requestOrigin }),
  getPageContent("servidores", { requestOrigin }),
  getPageContent("blog-tecnico", { requestOrigin }),
  getPageContent("soporte", { requestOrigin })
]);

const navigationItems = [
  { href: "/", label: "Inicio" },
  { href: "/redes-y-vpn", label: redesPage?.menuLabel || "Redes y VPN" },
  { href: "/servidores", label: servidoresPage?.menuLabel || "Servidores" },
  { href: "/blog-tecnico", label: blogPage?.menuLabel || "Blog técnico" },
  { href: "/soporte", label: soportePage?.menuLabel || "Soporte" }
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#153c6b" />
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container header-inner">
          <a class="brand-mark" href="/">
            {site?.logoPath && (
              <span class="brand-mark__media">
                <img
                  class="brand-mark__logo"
                  src={resolveMediaUrl(site.logoPath, requestOrigin)}
                  alt={`Logo de ${site?.companyName || "Soluciones TIC"}`}
                  loading="eager"
                />
              </span>
            )}
            <span class="brand-mark__text">
              <span class="brand-mark__title">{site?.companyName || "Soluciones TIC"}</span>
              <span class="brand-mark__tag">{site?.tagline || "Seguridad y conectividad profesional"}</span>
            </span>
          </a>

          <nav class="main-nav" aria-label="Principal">
            {navigationItems.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container footer-grid">
          <div>
            <p class="footer-title">{site?.companyName || "Soluciones TIC"}</p>
            <p class="footer-copy">{site?.footerNotice}</p>
          </div>

          <div>
            <p class="footer-title">Contacto</p>
            <a href={`mailto:${site?.email}`}>{site?.email}</a>
            <a href={`tel:${site?.phoneDisplay}`}>{site?.phoneDisplay}</a>
            <p>{site?.location}</p>
          </div>

          <div>
            <p class="footer-title">Cobertura</p>
            <p>{site?.coverageNote}</p>
            <a class="footer-editor-link" href="/admin">Acceso editor</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
