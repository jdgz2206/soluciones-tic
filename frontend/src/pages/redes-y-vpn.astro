---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageContent, getSiteSettings } from "../lib/api.js";
import { buildCanonical } from "../lib/seo.js";
import { buildWhatsAppUrl } from "../lib/whatsapp.js";

const [site, page] = await Promise.all([getSiteSettings(), getPageContent("redes-y-vpn")]);
const ctaUrl = buildWhatsAppUrl(site.whatsappNumber, page.ctaMessage || site.secondaryWhatsappMessage);
---

<BaseLayout
  site={site}
  title={page.metaTitle}
  description={page.metaDescription}
  canonical={buildCanonical("/redes-y-vpn")}
>
  <section class="page-hero">
    <div class="container page-grid">
      <article class="page-shell">
        <p class="page-eyebrow">{page.eyebrow}</p>
        <h1>{page.heroTitle}</h1>
        <p>{page.heroIntro}</p>
        <div class="hero-actions">
          <a class="button button--primary" href={ctaUrl} target="_blank" rel="noreferrer">
            {page.ctaLabel}
          </a>
        </div>
      </article>

      <aside class="page-info-grid">
        <article class="info-card">
          <span>Especialidad</span>
          <strong>{page.title}</strong>
          <p>{site.coverageNote}</p>
        </article>
        <article class="info-card">
          <span>Contacto</span>
          <strong>{site.phoneDisplay}</strong>
          <p>{site.email}</p>
        </article>
      </aside>
    </div>
  </section>

  <section>
    <div class="container page-sections">
      {page.sections.map((section) => (
        <article class="page-section">
          <h2>{section.title}</h2>
          <p>{section.content}</p>
          <ul>
            {section.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="container trust-banner">
      <div class="section-heading">
        <p class="section-eyebrow">{page.eyebrow}</p>
        <h2>{page.title}</h2>
        <p>{page.heroIntro}</p>
      </div>

      <div class="hero-actions">
        <a class="button button--primary" href={ctaUrl} target="_blank" rel="noreferrer">
          {page.ctaLabel}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
